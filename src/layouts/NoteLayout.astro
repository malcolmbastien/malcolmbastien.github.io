---
import Layout from "./Layout.astro";
import TableOfContents from "../components/Navigation/TableOfContents.astro";
import AboutAuthor from "../components/AboutAuthor.astro";
import Backlinks from "../components/Backlinks.astro";
import ImageLightbox from "../components/ImageLightbox.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { getReadingTime } from "../lib/reading-time";
import BackToGarden from "../components/Navigation/BackToGarden.astro";
import { getStageData } from "../lib/theme";
import TopicBadge from "../components/TopicBadge.astro";

interface Props {
    frontmatter: {
        title: string;
        publishedDate?: Date;
        stage: "seed" | "sprout" | "evergreen";
        summary?: string;
        tags: string[];
        draft?: boolean;
        featuredImage?: any;
        featuredImageAlt?: string;
        featured?: boolean;
        cover?: any;
    };
    backlinkedNotes: any[];
    noteBody?: string;
    headings?: any[];
}

const { frontmatter, backlinkedNotes, noteBody, headings } = Astro.props;

const readingTime = noteBody ? getReadingTime(noteBody) : "";
const stageData = getStageData(frontmatter.stage);

const createdDate = frontmatter.publishedDate || new Date();
const isNoteDraft = frontmatter.draft === true;

const formatDate = (date: Date) => {
    return date.toLocaleDateString("en-US", {
        year: "numeric",
        month: "long",
        day: "numeric",
        timeZone: "UTC",
    });
};


---

<Layout
    title={frontmatter.title}
    description={frontmatter.summary}
    image={frontmatter.featuredImage?.src || frontmatter.cover?.src}
    type="article"
    publishedTime={createdDate.toISOString()}
    tags={frontmatter.tags}
>
    <main class="pt-24 lg:pt-32">
        <div class="max-w-7xl mx-auto px-8">
            <div class="flex flex-col md:flex-row gap-20">
                <!-- Left Sidebar - TOC -->
                <aside class="w-80 shrink-0">
                    <div class="sticky top-32 space-y-12">
                        <div class="shrink-0">
                            <TableOfContents headings={headings} minHeadings={1} title="Contents" variant="note" class="toc-note" />
                        </div>
                    </div>
                </aside>

                <!-- Main Content -->
                <div class="grow" data-pagefind-body data-pagefind-filter="type:note">
                    <!-- Draft Banner -->
                    {isNoteDraft && (
                        <div class="draft-banner mb-6 px-4 py-3 border-l-4 border-dashed border-slate-400 dark:border-slate-500 bg-slate-50 dark:bg-slate-800/50 rounded-r">
                            <div class="flex items-center gap-2 text-slate-600 dark:text-slate-400">
                                <span class="material-symbols-outlined text-sm">edit_note</span>
                                <span class="text-sm font-medium">Draft Post — This post is a draft and is unlisted.</span>
                            </div>
                        </div>
                    )}

                    <!-- Article Header -->
                    <header class="mb-16">
                        <div class="max-w-180">
                            <div class="flex items-center gap-3 mb-6">
                                {readingTime && (
                                    <>
                                        <span class="text-slate-500 dark:text-slate-400 text-[0.75rem] font-medium tracking-wide">{readingTime}</span>
                                        <span class="text-slate-300 dark:text-slate-600 text-[0.75rem]">•</span>
                                    </>
                                )}
                                <span class="text-slate-500 dark:text-slate-400 text-[0.75rem] font-medium tracking-wide italic">{formatDate(createdDate)}</span>
                                <span class={`inline-flex items-center px-2 py-1 ${stageData.colors.bgAccent} border-l-2 ${stageData.colors.border} text-[10px] font-bold ${stageData.colors.text} tracking-wider uppercase`}>
                                    {stageData.label}
                                </span>
                            </div>
                            <h1 class="text-slate-900 dark:text-white text-5xl md:text-6xl font-extrabold tracking-tighter leading-tight mb-8">
                                {frontmatter.title}
                            </h1>
                            {frontmatter.summary && (
                                <p class="text-slate-600 dark:text-slate-400 text-xl font-light leading-relaxed border-l-4 border-blue-600 dark:border-blue-500 pl-6">
                                    {frontmatter.summary}
                                </p>
                            )}
                            {frontmatter.tags.length > 0 && (
                                <div class="flex flex-wrap gap-2 mt-8">
                                    {frontmatter.tags.map(tag => (
                                        <TopicBadge topic={tag} size="sm" />
                                    ))}
                                </div>
                            )}
                        </div>
                    </header>

                    <!-- Article Body -->
                    <article class="prose prose-slate dark:prose-invert prose-lg max-w-180">
                        <slot />

                        {backlinkedNotes.length > 0 && (
                            <div class="backlinks mt-16 pt-8 border-t border-slate-100 dark:border-slate-800">
                                <Backlinks backlinkedNotes={backlinkedNotes} />
                            </div>
                        )}
                    </article>

                    <!-- Author Profile at Bottom -->
                    <div class="mt-20 pt-16 border-t border-slate-200 dark:border-slate-800">
                        <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-12 max-w-180">
                            <!-- Author Meta -->
                            <div class="flex items-center gap-6">
                                <div class="w-16 h-16 rounded-lg bg-slate-100 dark:bg-slate-800 overflow-hidden shrink-0">
                                    <img
                                        src="/malcolm_headshot.png"
                                        alt="Malcolm Bastien"
                                        class="w-full h-full object-cover"
                                    />
                                </div>
                                <div>
                                    <p class="text-base font-bold text-slate-900 dark:text-white">Malcolm Bastien</p>
                                    <p class="text-xs text-slate-400 uppercase tracking-widest mb-2">Agile Delivery & Organizational Change</p>
                                    <p class="text-sm text-slate-500 dark:text-slate-400 max-w-md leading-relaxed">
                                        Unlocking flow through the alignment of socio-technical systems, AI, and product thinking.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <div class="pb-16"></div>

    <SiteFooter />

    <ImageLightbox />

    <style is:global>
        @reference "../styles/global.css";

        /* TOC Active Link */
        .toc-link.active {
            color: #003fe5 !important;
            border-left-color: #003fe5 !important;
            font-weight: 500;
        }

        .dark .toc-link.active {
            color: #60a5fa !important;
            border-left-color: #60a5fa !important;
            font-weight: 500;
        }

        /* Backlinks section */
        .prose .backlinks a {
            text-decoration: none !important;
            color: inherit !important;
            font-weight: inherit !important;
            font-family: inherit !important;
        }

        .prose .backlinks h4 {
            color: #0f172a !important;
        }
        .dark .prose .backlinks h4 {
            color: #f1f5f9 !important;
        }
        .prose .backlinks article:hover h4 {
            color: #1e3a8a !important;
        }
        .dark .prose .backlinks article:hover h4 {
            color: #60a5fa !important;
        }

        .prose blockquote {
            border-left-color: var(--color-primary);
        }

        /* Callout base styles - full width with right rounded corners */
        .prose .callout-block {
            margin: 1rem 0 !important;
            padding: 1rem !important;
            border-radius: 0 0.5rem 0.5rem 0 !important;
            border-left-width: 4px !important;
            border-left-style: solid !important;
            border-top: none !important;
            border-right: none !important;
            border-bottom: none !important;
            width: 100% !important;
        }

        /* Light mode callout styles */
        .prose .callout-block[data-callout-type="note"] { background-color: #eeeff3 !important; border-left-color: #993fe5 !important; }
        .prose .callout-block[data-callout-type="abstract"] { background-color: #ecfeff !important; border-left-color: #0891b2 !important; }
        .prose .callout-block[data-callout-type="info"] { background-color: #eff6ff !important; border-left-color: #3b82f6 !important; }
        .prose .callout-block[data-callout-type="example"] { background-color: #eef2ff !important; border-left-color: #6366f1 !important; }
        .prose .callout-block[data-callout-type="tip"] { background-color: #ecfdf5 !important; border-left-color: #10b981 !important; }
        .prose .callout-block[data-callout-type="important"] { background-color: #fff1f2 !important; border-left-color: #e11d48 !important; }
        .prose .callout-block[data-callout-type="todo"] { background-color: #dde1ff !important; border-left-color: #335cff !important; }
        .prose .callout-block[data-callout-type="success"] { background-color: #f0fdf4 !important; border-left-color: #22c55e !important; }
        .prose .callout-block[data-callout-type="question"] { background-color: #eef2ff !important; border-left-color: #6366f1 !important; }
        .prose .callout-block[data-callout-type="warning"] { background-color: #fffafb !important; border-left-color: #f59e0b !important; }
        .prose .callout-block[data-callout-type="failure"] { background-color: #ffdada !important; border-left-color: #ba1a1a !important; }
        .prose .callout-block[data-callout-type="error"] { background-color: #ffdada !important; border-left-color: #ba1a1a !important; }
        .prose .callout-block[data-callout-type="danger"] { background-color: #ffdada !important; border-left-color: #ba1a1a !important; }
        .prose .callout-block[data-callout-type="bug"] { background-color: #f1f5f9 !important; border-left-color: #475569 !important; }
        .prose .callout-block[data-callout-type="idea"] { background-color: #fefce8 !important; border-left-color: #eab308 !important; }
        .prose .callout-block[data-callout-type="quote"] { background-color: #f9f9fc !important; border-left-color: #c4c5d9 !important; }
        .prose .callout-block[data-callout-type="draft"] { background-color: #f5f3ff !important; border-left-color: #8b5cf6 !important; border-left-style: dashed !important; }
        .prose .callout-block[data-callout-type="wip"] { background-color: #f5f3ff !important; border-left-color: #8b5cf6 !important; border-left-style: dashed !important; }

        /* Dark mode callout overrides */
        .dark .prose .callout-block[data-callout-type="note"] { background-color: #2b244d !important; border-left-color: #c4b5fd !important; }
        .dark .prose .callout-block[data-callout-type="abstract"] { background-color: #083344 !important; border-left-color: #22d3ee !important; }
        .dark .prose .callout-block[data-callout-type="info"] { background-color: #1e3a5f !important; border-left-color: #60a5fa !important; }
        .dark .prose .callout-block[data-callout-type="example"] { background-color: #1e1b4b !important; border-left-color: #a5b4fc !important; }
        .dark .prose .callout-block[data-callout-type="tip"] { background-color: #064e3b !important; border-left-color: #34d399 !important; }
        .dark .prose .callout-block[data-callout-type="important"] { background-color: #4c0519 !important; border-left-color: #fb7185 !important; }
        .dark .prose .callout-block[data-callout-type="todo"] { background-color: #1e1b4b !important; border-left-color: #a5b4fc !important; }
        .dark .prose .callout-block[data-callout-type="success"] { background-color: #14532d !important; border-left-color: #4ade80 !important; }
        .dark .prose .callout-block[data-callout-type="question"] { background-color: #1e1b4b !important; border-left-color: #a5b4fc !important; }
        .dark .prose .callout-block[data-callout-type="warning"] { background-color: #451a03 !important; border-left-color: #fbbf24 !important; }
        .dark .prose .callout-block[data-callout-type="failure"] { background-color: #450a0a !important; border-left-color: #fca5a5 !important; }
        .dark .prose .callout-block[data-callout-type="error"] { background-color: #450a0a !important; border-left-color: #fca5a5 !important; }
        .dark .prose .callout-block[data-callout-type="danger"] { background-color: #450a0a !important; border-left-color: #fca5a5 !important; }
        .dark .prose .callout-block[data-callout-type="bug"] { background-color: #1e293b !important; border-left-color: #94a3b8 !important; }
        .dark .prose .callout-block[data-callout-type="idea"] { background-color: #422006 !important; border-left-color: #fde047 !important; }
        .dark .prose .callout-block[data-callout-type="quote"] { background-color: #1e293b !important; border-left-color: #c4c5d9 !important; }
        .dark .prose .callout-block[data-callout-type="draft"] { background-color: #2e1065 !important; border-left-color: #c4b5fd !important; border-left-style: dashed !important; }
        .dark .prose .callout-block[data-callout-type="wip"] { background-color: #2e1065 !important; border-left-color: #c4b5fd !important; border-left-style: dashed !important; }

        /* Dark mode internal text colors */
        .dark .prose .callout-block .callout-body p,
        .dark .prose .callout-block .callout-body li {
            color: #f1f5f9 !important;
        }

        .dark .prose .callout-block[data-callout-type="note"] .callout-header span { color: #c4b5fd !important; }
        .dark .prose .callout-block[data-callout-type="abstract"] .callout-header span { color: #22d3ee !important; }
        .dark .prose .callout-block[data-callout-type="info"] .callout-header span { color: #60a5fa !important; }
        .dark .prose .callout-block[data-callout-type="example"] .callout-header span { color: #a5b4fc !important; }
        .dark .prose .callout-block[data-callout-type="tip"] .callout-header span { color: #34d399 !important; }
        .dark .prose .callout-block[data-callout-type="important"] .callout-header span { color: #fb7185 !important; }
        .dark .prose .callout-block[data-callout-type="todo"] .callout-header span { color: #a5b4fc !important; }
        .dark .prose .callout-block[data-callout-type="success"] .callout-header span { color: #4ade80 !important; }
        .dark .prose .callout-block[data-callout-type="question"] .callout-header span { color: #a5b4fc !important; }
        .dark .prose .callout-block[data-callout-type="warning"] .callout-header span { color: #fbbf24 !important; }
        .dark .prose .callout-block[data-callout-type="failure"] .callout-header span,
        .dark .prose .callout-block[data-callout-type="error"] .callout-header span,
        .dark .prose .callout-block[data-callout-type="danger"] .callout-header span { color: #fca5a5 !important; }
        .dark .prose .callout-block[data-callout-type="bug"] .callout-header span { color: #94a3b8 !important; }
        .dark .prose .callout-block[data-callout-type="idea"] .callout-header span { color: #fde047 !important; }
        .dark .prose .callout-block[data-callout-type="quote"] .callout-header span { color: #a5b4fc !important; }
        .dark .prose .callout-block[data-callout-type="draft"] .callout-header span,
        .dark .prose .callout-block[data-callout-type="wip"] .callout-header span { color: #c4b5fd !important; }

        .prose h2, .prose h3, .prose h4, .prose h5, .prose h6 {
            font-family: "Plus Jakarta Sans", system-ui, sans-serif;
            color: #0f172a;
            font-weight: 700;
            letter-spacing: -0.025em;
            scroll-margin-top: 6rem;
        }

        .dark .prose h2,
        .dark .prose h3,
        .dark .prose h4,
        .dark .prose h5,
        .dark .prose h6 {
            color: #f1f5f9;
        }

        .prose h2 { font-size: 1.875rem; margin-top: 3rem; margin-bottom: 1.5rem; }
        .prose h3 { font-size: 1.5rem; margin-top: 2rem; margin-bottom: 1rem; }

        /* Inline Topic Links */
        .prose a.inline-tag {
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
            font-size: 0.75rem;
            font-weight: 500;
            color: #475569;
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 9999px;
            padding: 0.375rem 0.75rem;
            margin: 0.125rem;
            text-decoration: none;
            transition: all 0.2s;
        }

        .dark .prose a.inline-tag {
            color: #cbd5e1;
            background: #1e293b;
            border-color: #334155;
        }

        .prose a.inline-tag:hover {
            border-color: #003fe5;
            color: white;
            background: #003fe5;
        }

        /* Draft Container */
        .prose .draft-container {
            margin: 1.5rem 0 !important;
            padding: 1rem 1.25rem !important;
            border-radius: 0 0.5rem 0.5rem 0 !important;
            border-left: 3px dashed #94a3b8 !important;
            background-color: #f8fafc !important;
            position: relative !important;
        }

        .prose .draft-container::before {
            content: "DRAFT" !important;
            position: absolute !important;
            top: -0.75rem !important;
            right: 1rem !important;
            font-size: 10px !important;
            font-weight: 700 !important;
            text-transform: uppercase !important;
            letter-spacing: 0.1em !important;
            color: #64748b !important;
            background-color: #f8fafc !important;
            padding: 0 0.5rem !important;
        }

        .dark .prose .draft-container {
            background-color: #1e293b !important;
            border-left-color: #64748b !important;
        }

        .dark .prose .draft-container::before {
            color: #94a3b8 !important;
            background-color: #1e293b !important;
        }

        .prose .draft-container * {
            opacity: 0.85 !important;
        }

        .prose .draft-container p:last-child {
            margin-bottom: 0 !important;
        }

        /* List spacing */
        .prose li {
            margin-top: 0.25rem;
            margin-bottom: 0.25rem;
        }

        .prose li > p {
            margin-top: 0.25rem;
            margin-bottom: 0.25rem;
        }
    </style>
</Layout>
