---
import Layout from "../layouts/Layout.astro";
import SiteFooter from "../components/SiteFooter.astro";

const title = "404 - Page Not Found | Flow Focused";
const description = "The page you're looking for doesn't exist or may have been moved.";
---

<Layout title={title} description={description}>
    <main class="min-h-screen flex items-center justify-center px-6 relative overflow-hidden w-full pt-20" data-pagefind-ignore>
        <div class="max-w-2xl w-full text-center relative z-10">
            <div class="mb-8">
                <span class="text-[0.75rem] uppercase tracking-[0.2em] font-bold text-primary block mb-4">Error Code: 404</span>
                <h1 class="text-7xl md:text-9xl font-bold tracking-tighter text-slate-900 dark:text-white leading-none">
                    Page Not Found
                </h1>
            </div>

            <div class="space-y-6 mb-12">
                <p class="text-xl md:text-2xl text-slate-500 dark:text-slate-400 leading-relaxed max-w-lg mx-auto">
                    The page you’re looking for doesn’t exist or may have been moved.
                </p>
                <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                    <a class="inline-flex items-center justify-center bg-primary text-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-blue-700 transition-all active:scale-95 group" href="/">
                        Back to Garden
                        <span class="material-symbols-outlined ml-2 group-hover:translate-x-1 transition-transform">arrow_forward</span>
                    </a>
                </div>
            </div>

            <div class="pt-12 border-t border-slate-200/30 dark:border-slate-700/30 max-w-md mx-auto">
                <p class="text-sm font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-6">What would you like to do?</p>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                    <a class="group p-4 bg-slate-100 dark:bg-slate-800 rounded-xl hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors text-left" href="/">
                        <span class="material-symbols-outlined text-primary mb-2 block">home</span>
                        <span class="font-bold text-sm block text-slate-900 dark:text-white">Go Home</span>
                    </a>
                    <a class="group p-4 bg-slate-100 dark:bg-slate-800 rounded-xl hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors text-left" href="/topics">
                        <span class="material-symbols-outlined text-primary] mb-2 block">topic</span>
                        <span class="font-bold text-sm block text-slate-900 dark:text-white">Browse Topics</span>
                    </a>
                    <a class="group p-4 bg-slate-100 dark:bg-slate-800 rounded-xl hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors text-left" href="/about">
                        <span class="material-symbols-outlined text-primary mb-2 block">person</span>
                        <span class="font-bold text-sm block text-slate-900 dark:text-white">About Malcolm</span>
                    </a>
                </div>
            </div>
        </div>

        <div class="absolute bottom-0 right-0 p-12 opacity-10 hidden lg:block pointer-events-none">
            <span class="material-symbols-outlined text-[20rem] text-slate-400" style="font-variation-settings: 'wght' 100;">architecture</span>
        </div>
    </main>
    <SiteFooter />
</Layout>

<style>
    @reference "../styles/global.css";
</style>
