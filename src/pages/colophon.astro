---
import Layout from "../layouts/Layout.astro";
import SiteFooter from "../components/SiteFooter.astro";

const developmentTools = [
    {
        name: "Zed",
        description: "A high-performance code editor written in Rust, chosen for its near-zero latency and collaborative environment. It serves as the primary forge for our codebase.",
        link: "https://zed.dev",
    },
    {
        name: "Open Code AI",
        description: "An interactive coding tool that assists in architectural decisions and boilerplate reduction, ensuring the logic remains consistent with the \"Blueprint\" philosophy.",
        link: "https://opencode.ai",
    },
    {
        name: "Google Stitch",
        description: "The primary design tool used for creating and maintaining the visual language and component systems of Flow Focused.",
        link: "https://stitch.withgoogle.com",
    }
];

const workflowTools = [
    {
        name: "Obsidian",
        description: "The 'Second Brain' where all Markdown writing happens. Its graph-based structure allows for emergent ideas to connect before they ever reach a draft state.",
        link: "https://obsidian.md",
    },
    {
        name: "Obsidian Git",
        description: "Seamless publishing through automated commits. This bridge ensures that the distance between a 'Note' and a 'Published Post' is just a single shortcut away.",
        link: "https://github.com/denolehov/obsidian-git",
    }
];

const deploymentTools = [
    {
        name: "Vercel",
        description: "Static site generation paired with edge deployment provides sub-100ms load times globally. We leverage Vercel's global infrastructure for its unparalleled DX and speed.",
        link: "https://vercel.com",
    }
];

const techStack = [
    {
        name: "Astro",
        description: "The web framework for content-driven websites. Ship less JS, more performance.",
        link: "https://astro.build",
    },
    {
        name: "Tailwind CSS",
        description: "Utility-first CSS framework for rapid UI development without leaving the HTML.",
        link: "https://tailwindcss.com",
    },
    {
        name: "Pagefind",
        description: "Zero-config static search library that works entirely on the client side.",
        link: "https://pagefind.app",
    },
    {
        name: "@astrojs/sitemap",
        description: "Automated SEO infrastructure for discoverability across the open web.",
        link: "https://docs.astro.build/en/guides/integrations-guide/sitemap/",
    },
    {
        name: "Remark & Unist",
        description: "The pipeline that transforms Markdown into structured, accessible HTML.",
        link: "https://remark.js.org/",
    }
];
---

<Layout
    title="Colophon | Flow Focused"
    description="A technical index of the tools, systems, and philosophies that power this digital garden."
    type="website"
>
    <main class="mx-auto px-gutter" data-pagefind-ignore>
        <!-- Hero Section -->
        <section class="bg-paper-white dark:bg-ink-slate pt-20 pb-16 px-gutter border-b border-border-muted dark:border-outline-variant">
            <div class="max-w-180 mx-auto text-center">
                <h1 class="font-display text-display-lg text-ink-slate dark:text-inverse-on-surface mb-6">Colophon</h1>
                <p class="text-body-lg text-on-surface-variant dark:text-outline-variant">
                    A technical index of the tools, systems, and philosophies that power this digital garden. Built for speed, legibility, and architectural rigor.
                </p>
            </div>
        </section>

        <!-- Content Grid -->
        <div class="max-w-5xl mx-auto py-section-gap grid grid-cols-1 md:grid-cols-2 gap-y-16 md:gap-x-gutter">
            <!-- Development & Tools -->
            <div class="flex flex-col gap-6">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-terracotta-accent">terminal</span>
                    <h2 class="text-label-caps text-on-surface-variant dark:text-outline-variant uppercase tracking-widest">Development &amp; Tools</h2>
                </div>
                <div class="flex flex-col gap-8">
                    {developmentTools.map((tool) => (
                        <div class="group">
                            <h3 class="font-display text-headline-sm text-ink-slate dark:text-inverse-on-surface mb-2 group-hover:text-terracotta-accent transition-colors">
                                <a href={tool.link} target="_blank" rel="noopener noreferrer">{tool.name}</a>
                            </h3>
                            <p class="text-body-md text-on-surface-variant dark:text-outline-variant">{tool.description}</p>
                        </div>
                    ))}
                </div>
            </div>

            <!-- Writing Workflow & Hosting -->
            <div class="flex flex-col gap-12">
                <div class="flex flex-col gap-6">
                    <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-terracotta-accent">history_edu</span>
                        <h2 class="text-label-caps text-on-surface-variant dark:text-outline-variant uppercase tracking-widest">Writing Workflow</h2>
                    </div>
                    <div class="flex flex-col gap-8">
                        {workflowTools.map((tool) => (
                            <div class="group">
                                <h3 class="font-display text-headline-sm text-ink-slate dark:text-inverse-on-surface mb-2 group-hover:text-terracotta-accent transition-colors">
                                    <a href={tool.link} target="_blank" rel="noopener noreferrer">{tool.name}</a>
                                </h3>
                                <p class="text-body-md text-on-surface-variant dark:text-outline-variant">{tool.description}</p>
                            </div>
                        ))}
                    </div>
                </div>

                <div class="flex flex-col gap-6 pt-8 border-t border-border-muted dark:border-outline-variant">
                    <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-terracotta-accent">cloud_done</span>
                        <h2 class="text-label-caps text-on-surface-variant dark:text-outline-variant uppercase tracking-widest">Hosting &amp; Deployment</h2>
                    </div>
                    {deploymentTools.map((tool) => (
                        <div class="group">
                            <h3 class="font-display text-headline-sm text-ink-slate dark:text-inverse-on-surface mb-2 group-hover:text-terracotta-accent transition-colors">
                                <a href={tool.link} target="_blank" rel="noopener noreferrer">{tool.name}</a>
                            </h3>
                            <p class="text-body-md text-on-surface-variant dark:text-outline-variant">{tool.description}</p>
                        </div>
                    ))}
                </div>
            </div>

        </div>

        <!-- Typography Section -->
        <section class="bg-paper-white dark:bg-ink-slate py-20 border-y border-border-muted dark:border-outline-variant">
            <div class="max-w-5xl mx-auto px-gutter">
                <div class="flex flex-col md:flex-row justify-between items-start mb-16 gap-8">
                    <div class="max-w-3xl">
                        <div class="flex items-center gap-3 mb-6">
                            <span class="material-symbols-outlined text-terracotta-accent">format_size</span>
                            <h2 class="text-label-caps text-on-surface-variant dark:text-outline-variant uppercase tracking-widest">Typography</h2>
                        </div>
                        <p class="text-body-lg text-on-surface-variant dark:text-outline-variant">Our typographic system is designed for high-density information without compromising the editorial warmth of a physical journal.</p>
                    </div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-16">
                <div class="border-l-2 border-border-muted dark:border-outline-variant pl-8 py-2">
                    <h4 class="text-label-caps text-terracotta-accent mb-4">UI &amp; Headlines</h4>
                    <span class="block text-display-lg mb-4" style="font-family: 'Inter', sans-serif; font-weight: 700;">Inter</span>
                    <p class="text-body-md text-on-surface-variant dark:text-outline-variant">The primary typeface for UI elements, navigation, and body copy. Neutral and highly legible at any size.</p>
                </div>
                <div class="border-l-2 border-terracotta-accent pl-8 py-2">
                    <h4 class="text-label-caps text-terracotta-accent mb-4">Article Body</h4>
                    <span class="block font-display text-display-lg mb-4">Newsreader</span>
                    <p class="text-body-md text-on-surface-variant dark:text-outline-variant">Provides editorial warmth and readability for long-form article content and blockquotes.</p>
                </div>
                <div class="border-l-2 border-border-muted dark:border-outline-variant pl-8 py-2">
                    <h4 class="text-label-caps text-terracotta-accent mb-4">Syntax &amp; Technical</h4>
                    <span class="block font-mono text-display-lg mb-4">JetBrains Mono</span>
                    <p class="text-body-md text-on-surface-variant dark:text-outline-variant">Designed for code clarity with ligatures and distinctive letterforms for syntax distinction.</p>
                </div>
                <div class="border-l-2 border-border-muted dark:border-outline-variant pl-8 py-2">
                    <h4 class="text-label-caps text-terracotta-accent mb-4">Iconography</h4>
                    <span class="block material-symbols-outlined mb-4" style="font-size: 48px;">palette</span>
                    <p class="text-body-md text-on-surface-variant dark:text-outline-variant mb-6">Material Symbols Variable weight (100-700). Outlined icon set for consistent, modern UI iconography.</p>
                </div>
                </div>
            </div>
        </section>

        <!-- Tech Stack Section -->
        <section class="max-w-5xl mx-auto py-section-gap">
            <div class="flex items-center gap-3 mb-12">
                <span class="material-symbols-outlined text-terracotta-accent">schema</span>
                <h2 class="text-label-caps text-on-surface-variant dark:text-outline-variant uppercase tracking-widest">Technology Stack</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                {techStack.map((pkg) => (
                    <a href={pkg.link} target="_blank" rel="noopener noreferrer" class="p-6 bg-paper-white dark:bg-ink-slate border border-border-muted dark:border-outline-variant hover:border-terracotta-accent transition-colors group">
                        <h4 class="font-display text-[20px] text-ink-slate dark:text-inverse-on-surface mb-3 group-hover:text-terracotta-accent transition-colors">{pkg.name}</h4>
                        <p class="text-body-md text-on-surface-variant dark:text-outline-variant">{pkg.description}</p>
                    </a>
                ))}
            </div>
        </section>
    </main>
    <SiteFooter />
</Layout>
