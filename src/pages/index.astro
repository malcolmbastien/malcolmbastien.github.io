---
import { getCollection } from "astro:content";
import { statSync } from "node:fs";
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import HeroBanner from "../components/HeroBanner.astro";

const allNotes = await getCollection("notes");

const notesWithDates = allNotes
    .filter((note) => !note.data.draft)
    .map((note) => {
        let displayDate: Date;
        if (note.data.publishedDate) {
            displayDate = new Date(note.data.publishedDate);
        } else {
            const stats = statSync(note.filePath || `src/content/notes/${note.id}`);
            displayDate = stats.birthtime;
        }
        return { ...note, displayDate };
    });

const sortedNotes = notesWithDates.sort((a, b) => {
    const dateA = a.displayDate as Date;
    const dateB = b.displayDate as Date;
    return dateB.valueOf() - dateA.valueOf();
});

const pinnedNotes = allNotes.filter((note) => (note.data as any).pinned === true);

const recentNotes = sortedNotes.slice(0, 3);

const formatDate = (date: Date) => {
    return date.toLocaleDateString("en-US", {
        year: "numeric",
        month: "short",
        day: "numeric",
        timeZone: "UTC",
    });
};
---

<Layout
    title="Malcolm Bastien - Flow Focused"
    description="A digital garden of thoughts and ideas. Explore seeds, sprouts, and evergreens of knowledge in this ever-growing collection of writings."
    type="website"
>
    <HeroBanner />

    <main>
        <!-- Latest Articles / Blog Section -->
        <section class="pt-12 pb-section-gap bg-paper-white dark:bg-ink-slate" id="articles">
            <div class="max-w-180 mx-auto px-gutter">
                <h2 class="font-display text-headline-md text-ink-slate dark:text-inverse-on-surface mb-8">Recent Articles</h2>
                <div class="space-y-0" data-pagefind-ignore>
                    {pinnedNotes.map((note) => (
                        <article class="group py-12 border-b border-border-muted dark:border-on-surface-variant last:border-0">
                            <div class="flex flex-col gap-4">
                                <div class="flex items-center gap-4">
                                    <span class="text-mono-sm text-on-surface-variant dark:text-outline-variant">
                                        {note.data.publishedDate ? formatDate(note.data.publishedDate) : 'Draft'}
                                    </span>
                                    <span class="w-1 h-1 rounded-full bg-outline-variant dark:bg-outline"></span>
                                    <span class="text-mono-sm text-terracotta-accent">Pinned</span>
                                </div>
                                <a class="block" href={`/notes/${note.id.replace('.md', '')}`}>
                                    <h2 class="font-display text-headline-md text-ink-slate dark:text-inverse-on-surface group-hover:text-terracotta-accent dark:group-hover:text-terracotta-accent transition-colors duration-300">
                                        {note.data.title}
                                    </h2>
                                </a>
                                {note.data.summary && (
                                    <p class="text-body-md text-on-surface-variant dark:text-outline-variant line-clamp-3">
                                        {note.data.summary}
                                    </p>
                                )}
                                <a class="text-label-caps flex items-center gap-2 text-ink-slate dark:text-inverse-on-surface hover:translate-x-1 transition-transform w-fit mt-2" href={`/notes/${note.id.replace('.md', '')}`}>
                                    Read Article <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
                                </a>
                            </div>
                        </article>
                    ))}

                    {recentNotes.map((note) => {
                        const hasCover = note.data.cover;
                        return (
                        <article class="group py-12 border-b border-border-muted dark:border-on-surface-variant last:border-0">
                            <div class={`flex ${hasCover ? 'flex-col md:flex-row gap-8 items-start' : 'flex-col gap-4'}`}>
                                {hasCover && (
                                    <div class="w-full bg-canvas-gray dark:bg-ink-slate/50 overflow-hidden md:w-32 aspect-square shrink-0">
                                        <Image
                                            src={note.data.cover!}
                                            alt={note.data.title}
                                            width={512}
                                            height={512}
                                            class="w-full h-full object-cover"
                                        />
                                    </div>
                                )}
                                <div class={`flex flex-col gap-4 ${hasCover ? 'flex-1' : ''}`}>
                                    <div class="flex items-center gap-4">
                                        <span class="text-mono-sm text-on-surface-variant dark:text-outline-variant">
                                            {note.data.publishedDate ? formatDate(note.data.publishedDate) : ''}
                                        </span>
                                        {note.data.tags.length > 0 && (
                                            <>
                                                <span class="w-1 h-1 rounded-full bg-outline-variant dark:bg-outline"></span>
                                                <span class="text-mono-sm text-terracotta-accent">#{note.data.tags[0]}</span>
                                            </>
                                        )}
                                    </div>
                                    <a class="block" href={`/notes/${note.id.replace('.md', '')}`}>
                                        <h2 class="font-display text-headline-md text-ink-slate dark:text-inverse-on-surface group-hover:text-terracotta-accent dark:group-hover:text-terracotta-accent transition-colors duration-300">
                                            {note.data.title}
                                        </h2>
                                    </a>
                                    {note.data.summary && (
                                        <p class="text-body-md text-on-surface-variant dark:text-outline-variant line-clamp-3">
                                            {note.data.summary}
                                        </p>
                                    )}
                                    <a class="text-label-caps flex items-center gap-2 text-ink-slate dark:text-inverse-on-surface hover:translate-x-1 transition-transform w-fit mt-2" href={`/notes/${note.id.replace('.md', '')}`}>
                                        Read Article <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
                                    </a>
                                </div>
                            </div>
                        </article>
                        );
                    })}
                </div>

                <div class="mt-16 text-center">
                    <a class="inline-block border border-ink-slate dark:border-inverse-on-surface px-10 py-4 text-label-caps text-ink-slate dark:text-inverse-on-surface hover:bg-ink-slate dark:hover:bg-inverse-on-surface hover:text-paper-white dark:hover:text-ink-slate transition-all" href="/archives">
                        Browse all articles
                    </a>
                </div>
            </div>
        </section>
    </main>
</Layout>
