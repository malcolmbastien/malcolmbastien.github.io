---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
    const allNotes = await getCollection("notes");
    const topics = new Set<string>();
    allNotes.forEach((note) => {
        const tags = note.data.tags || [];
        tags.forEach((tag) => topics.add(tag.toLowerCase()));
    });
    return Array.from(topics).map((topic) => ({
        params: { topic },
    }));
}

const { topic } = Astro.params;

const displayTopic = topic ? topic.charAt(0).toUpperCase() + topic.slice(1) : '';

const allNotes = await getCollection("notes");
const filteredNotes = allNotes
    .filter((note) => !note.data.draft)
    .filter((note) => {
        const tags = note.data.tags || [];
        return tags.some((tag) => tag.toLowerCase() === topic?.toLowerCase());
    });

const sortedNotes = filteredNotes.sort(
    (a, b) => {
        const dateA = a.data.publishedDate ? new Date(a.data.publishedDate).getTime() : 0;
        const dateB = b.data.publishedDate ? new Date(b.data.publishedDate).getTime() : 0;
        return dateB - dateA;
    },
);

const formatDate = (date: Date | undefined) => {
    if (!date) return '';
    return date.toLocaleDateString("en-US", { month: 'short', day: '2-digit', year: 'numeric', timeZone: 'UTC' });
};
---

<Layout
    title={`${displayTopic} | Topic Archive`}
    description={`Explore all cultivated notes and ideas regarding ${displayTopic}.`}
    type="website"
>
    <main class="bg-paper-white dark:bg-ink-slate min-h-screen" data-pagefind-ignore>
        <!-- Breadcrumb -->
        <section class="max-w-280 mx-auto px-gutter pt-12">
            <div class="flex items-center gap-2 text-on-surface-variant">
                <span class="font-label-caps text-label-caps uppercase tracking-widest">Topic Archive</span>
            </div>
        </section>

        <!-- Topic Header -->
        <section class="max-w-280 mx-auto px-gutter pt-8 pb-16 border-b border-border-muted dark:border-on-surface-variant">
            <div class="flex flex-col md:flex-row md:items-baseline justify-between gap-4">
                <h1 class="font-display text-display-lg-mobile md:text-display-lg text-ink-slate dark:text-inverse-on-surface">
                    {displayTopic}
                </h1>
                <div class="bg-surface-container-low dark:bg-ink-slate/50 px-4 py-1 rounded-full inline-block">
                    <span class="font-mono-sm text-mono-sm text-terracotta-accent">{sortedNotes.length} Notes</span>
                </div>
            </div>
        </section>

        <!-- Post List -->
        <section class="max-w-280 mx-auto px-gutter py-16">
            <div class="max-w-180 mx-auto flex flex-col gap-12">
                {sortedNotes.map((note, index) => {
                    const hasCover = note.data.cover;
                    return (
                    <article class={`group ${note.data.featured ? 'bg-surface-container-lowest dark:bg-ink-slate/30 p-gutter -mx-gutter rounded-lg' : ''}`}>
                        <div class={`flex ${hasCover && note.data.featured ? 'flex-col md:flex-row gap-8 items-start' : 'flex-col gap-4'}`}>
                            {hasCover && note.data.featured && (
                                <div class="w-full bg-canvas-gray dark:bg-ink-slate/50 overflow-hidden md:w-32 aspect-square shrink-0">
                                    <Image
                                        src={note.data.cover!}
                                        alt={note.data.title}
                                        class="w-full h-full object-cover"
                                    />
                                </div>
                            )}
                            <div class={`${hasCover && note.data.featured ? 'flex-1' : ''}`}>
                                <div class="mb-2">
                                    <span class="font-label-caps text-label-caps text-on-surface-variant dark:text-outline-variant">
                                        {formatDate(note.data.publishedDate)}
                                    </span>
                                </div>
                                <h2 class="font-display text-headline-md mb-2">
                                    <a class="text-ink-slate dark:text-inverse-on-surface hover:text-terracotta-accent transition-colors duration-200" href={`/notes/${note.id.replace('.md', '')}`}>
                                        {note.data.title}
                                    </a>
                                </h2>
                                {note.data.summary && (
                                    <p class="font-sans text-body-md text-on-surface-variant dark:text-outline-variant leading-relaxed">
                                        {note.data.summary}
                                    </p>
                                )}
                            </div>
                        </div>
                    </article>
                    );
                })}

                <!-- View Archive Button -->
                <div class="pt-12 border-t border-border-muted dark:border-on-surface-variant flex justify-center">
                    <a href="/archives" class="px-8 py-3 bg-ink-slate dark:bg-paper-white text-paper-white dark:text-ink-slate font-label-caps text-label-caps uppercase tracking-widest hover:-translate-y-0.5 transition-transform duration-200 shadow-sm">
                        View Archive History
                    </a>
                </div>
            </div>
        </section>
    </main>
</Layout>
