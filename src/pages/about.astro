---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import portrait from "../assets/2026/01/malcolm_portrait.jpg";
---

<Layout
    title="About | Malcolm Bastien - The Editorial Architect"
    description="Lean-Agile Delivery and Agile Transformation Coach specializing in Agile transformation, sociotechnical design and program delivery for high-stakes, $10M+ initiatives."
    type="website"
>
    <main class="pb-section-gap" data-pagefind-ignore>
        <div class="max-w-5xl mx-auto px-gutter">
            <!-- Hero Section -->
            <section class="mx-auto py-16 flex flex-col md:flex-row items-center gap-12">
                <div class="w-40 md:w-56 shrink-0 overflow-hidden bg-surface-container dark:bg-ink-slate ring-4 ring-white dark:ring-ink-slate shadow-xl">
                    <Image
                        src={portrait}
                        alt="Malcolm Bastien"
                        class="w-full h-auto"
                        widths={[160, 224, 384, 512]}
                        sizes="(max-width: 768px) 160px, 224px"
                        quality={90}
                        loading="eager"
                    />
                </div>
                <div class="grow text-center md:text-left">
                    <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tighter text-ink-slate dark:text-inverse-on-surface mb-4 leading-[1.1]">
                        Malcolm Bastien
                    </h1>
                    <p class="text-xl md:text-2xl text-terracotta-accent font-semibold mb-4">
                        Lean-Agile Delivery and Transformation Coach
                    </p>
                    <p class="text-body-md text-on-surface-variant dark:text-outline-variant leading-relaxed max-w-2xl">
                        Helping clients achieve organizational flow by implementing real agile-enabling practices and fostering a culture of continuous improvement.
                    </p>
                    <div class="flex gap-4 mt-8 justify-center md:justify-start">
                        <a href="https://github.com/malcolmbastien" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="text-on-surface-variant dark:text-outline-variant hover:text-terracotta-accent transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8"/>
                            </svg>
                        </a>
                        <a href="https://www.linkedin.com/in/malcolmbastien/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-on-surface-variant dark:text-outline-variant hover:text-terracotta-accent transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
