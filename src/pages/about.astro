---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import portrait from "../assets/2026/01/malcolm_portrait.jpg";
---

<Layout
    title="About | Malcolm Bastien - The Editorial Architect"
    description="Senior Lean-Agile Delivery and Agile Transformation Coach specializing in Agile transformation, sociotechnical design and program delivery for high-stakes, $10M+ initiatives."
    type="website"
>
    <main class="pb-section-gap" data-pagefind-ignore>
        <div class="max-w-5xl mx-auto px-gutter">
            <!-- Hero Section -->
            <section class="mx-auto py-16 flex flex-col md:flex-row items-center gap-12">
                <div class="w-40 md:w-56 shrink-0 overflow-hidden bg-surface-container dark:bg-ink-slate ring-4 ring-white dark:ring-ink-slate shadow-xl">
                    <Image
                        src={portrait}
                        alt="Malcolm Bastien"
                        class="w-full h-auto"
                        widths={[160, 224, 384, 512]}
                        sizes="(max-width: 768px) 160px, 224px"
                        quality={90}
                    />
                </div>
                <div class="grow text-center md:text-left">
                    <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tighter text-ink-slate dark:text-inverse-on-surface mb-4 leading-[1.1]">
                        Malcolm Bastien
                    </h1>
                    <p class="text-xl md:text-2xl text-terracotta-accent font-semibold mb-4">
                        Senior Lean-Agile Delivery and Agile Transformation Coach
                    </p>
                    <p class="text-body-md text-on-surface-variant dark:text-outline-variant leading-relaxed max-w-2xl">
                        Helping clients achieve organizational flow by implementing real agile-enabling practices and fostering a culture of continuous improvement
                    </p>
                    <div class="flex gap-4 mt-8 justify-center md:justify-start">
                        <a href="https://github.com/malcolmbastien" target="_blank" rel="noopener noreferrer" class="text-on-surface-variant dark:text-outline-variant hover:text-terracotta-accent transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8"/>
                            </svg>
                        </a>
                        <a href="https://www.linkedin.com/in/malcolmbastien/" target="_blank" rel="noopener noreferrer" class="text-on-surface-variant dark:text-outline-variant hover:text-terracotta-accent transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z"/>
                            </svg>
                        </a>
                        <a href="https://mastodon.social/@malcolm" target="_blank" rel="noopener noreferrer me" class="text-on-surface-variant dark:text-outline-variant hover:text-terracotta-accent transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M11.19 12.195c2.016-.24 3.77-1.475 3.99-2.603.348-1.778.32-4.339.32-4.339 0-3.47-2.286-4.488-2.286-4.488C12.062.238 10.083.017 8.027 0h-.05C5.92.017 3.942.238 2.79.765c0 0-2.285 1.017-2.285 4.488l-.002.662c-.004.64-.007 1.35.011 2.091.083 3.394.626 6.74 3.78 7.57 1.454.383 2.703.463 3.709.408 1.823-.1 2.847-.647 2.847-.647l-.06-1.317s-1.303.41-2.767.36c-1.45-.05-2.98-.156-3.215-1.928a4 4 0 0 1-.033-.496s1.424.346 3.228.428c1.103.05 2.137-.064 3.188-.189zm1.613-2.47H11.13v-4.08c0-.859-.364-1.295-1.091-1.295-.804 0-1.207.517-1.207 1.541v2.233H7.168V5.89c0-1.024-.403-1.541-1.207-1.541-.727 0-1.091.436-1.091 1.296v4.079H3.197V5.522q0-1.288.66-2.046c.456-.505 1.052-.764 1.793-.764.856 0 1.504.328 1.933.983L8 4.39l.417-.695c.429-.655 1.077-.983 1.934-.983.74 0 1.336.259 1.791.764q.662.757.661 2.046z"/>
                            </svg>
                        </a>
                        <a href="https://matrix.to/#/@malcolmbastien:matrix.org" target="_blank" rel="noopener noreferrer" class="text-on-surface-variant dark:text-outline-variant hover:text-terracotta-accent transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M2.678 11.894a1 1 0 0 1 .287.801 11 11 0 0 1-.398 2c1.395-.323 2.247-.697 2.634-.893a1 1 0 0 1 .71-.074A8 8 0 0 0 8 14c3.996 0 7-2.807 7-6s-3.004-6-7-6-7 2.808-7 6c0 1.468.617 2.83 1.678 3.894m-.493 3.905a22 22 0 0 1-.713.129c-.2.032-.352-.176-.273-.362a10 10 0 0 0 .244-.637l.003-.01c.248-.72.45-1.548.524-2.319C.743 11.37 0 9.76 0 8c0-3.866 3.582-7 8-7s8 3.134 8 7-3.582 7-8 7a9 9 0 0 1-2.347-.306c-.52.263-1.639.742-3.468 1.105"/>
                                <path d="M4 5.5a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7a.5.5 0 0 1-.5-.5M4 8a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7A.5.5 0 0 1 4 8m0 2.5a.5.5 0 0 1 .5-.5h4a.5.5 0 0 1 0 1h-4a.5.5 0 0 1-.5-.5"/>
                            </svg>
                        </a>
                        <a href="https://www.instagram.com/malcolmbastien/" target="_blank" rel="noopener noreferrer" class="text-on-surface-variant dark:text-outline-variant hover:text-terracotta-accent transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.9 3.9 0 0 0-1.417.923A3.9 3.9 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.7.01 5.555 0 5.827 0 8.001c0 2.172.01 2.444.048 3.297.04.852.174 1.433.372 1.942.205.526.478.972.923 1.417.444.445.89.719 1.416.923.51.198 1.09.333 1.942.372C5.555 15.99 5.827 16 8 16s2.444-.01 3.298-.048c.851-.04 1.434-.174 1.943-.372a3.9 3.9 0 0 0 1.416-.923c.445-.445.718-.891.923-1.417.197-.509.332-1.09.372-1.942C15.99 10.445 16 10.173 16 8s-.01-2.445-.048-3.299c-.04-.851-.175-1.433-.372-1.941a3.9 3.9 0 0 0-.923-1.417A3.9 3.9 0 0 0 13.24.42c-.51-.198-1.092-.333-1.943-.372C10.443.01 10.172 0 7.998 0zm-.717 1.442h.718c2.136 0 2.389.007 3.232.046.78.035 1.204.166 1.486.275.373.145.64.319.92.599s.453.546.598.92c.11.281.24.705.275 1.485.039.843.047 1.096.047 3.231s-.008 2.389-.047 3.232c-.035.78-.166 1.203-.275 1.485a2.5 2.5 0 0 1-.599.919c-.28.28-.546.453-.92.598-.28.11-.704.24-1.485.276-.843.038-1.096.047-3.232.047s-2.39-.009-3.233-.047c-.78-.036-1.203-.166-1.485-.276a2.5 2.5 0 0 1-.92-.598 2.5 2.5 0 0 1-.6-.92c-.109-.281-.24-.705-.275-1.485-.038-.843-.046-1.096-.046-3.233s.008-2.388.046-3.231c.036-.78.166-1.204.276-1.486.145-.373.319-.64.599-.92s.546-.453.92-.598c.282-.11.705-.24 1.485-.276.738-.034 1.024-.044 2.515-.045zm4.988 1.328a.96.96 0 1 0 0 1.92.96.96 0 0 0 0-1.92m-4.27 1.122a4.109 4.109 0 1 0 0 8.217 4.109 4.109 0 0 0 0-8.217m0 1.441a2.667 2.667 0 1 1 0 5.334 2.667 2.667 0 0 1 0-5.334"/>
                            </svg>
                        </a>
                    </div>
                </div>
            </section>

            <!-- What I Do -->
            <section class="mb-section-gap" id="what-i-do">
                <div class="border-t border-border-muted dark:border-outline-variant pt-4 mb-12">
                    <h2 class="text-label-caps uppercase tracking-widest text-on-surface-variant dark:text-outline-variant">What I Do</h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                    <div class="group">
                        <span class="material-symbols-outlined text-terracotta-accent mb-4 block scale-125">trending_up</span>
                        <h4 class="font-display text-headline-sm text-ink-slate dark:text-inverse-on-surface mb-3 group-hover:text-terracotta-accent transition-colors">Promote Predictable Delivery</h4>
                        <p class="text-body-md text-on-surface-variant dark:text-outline-variant leading-relaxed">I help teams deliver better outcomes, faster, and more predictably by helping teams adopt agile-enabling practices and fostering a culture of rigorous continuous improvement.</p>
                    </div>
                    <div class="group">
                        <span class="material-symbols-outlined text-terracotta-accent mb-4 block scale-125">rocket_launch</span>
                        <h4 class="font-display text-headline-sm text-ink-slate dark:text-inverse-on-surface mb-3 group-hover:text-terracotta-accent transition-colors">Launch Complex Programs</h4>
                        <p class="text-body-md text-on-surface-variant dark:text-outline-variant leading-relaxed">I help organizations plan, organize, and run successful, high-stakes programs by breaking down ambiguous large-scale initiatives, aligning cross-functional stakeholders, and creating enabling team structures.</p>
                    </div>
                    <div class="group">
                        <span class="material-symbols-outlined text-terracotta-accent mb-4 block scale-125">groups</span>
                        <h4 class="font-display text-headline-sm text-ink-slate dark:text-inverse-on-surface mb-3 group-hover:text-terracotta-accent transition-colors">Empower Teams</h4>
                        <p class="text-body-md text-on-surface-variant dark:text-outline-variant leading-relaxed">I focus on building trust-based, high-performance environments where decision-making is moved to the team level, empowering them to solve their own challenges.</p>
                    </div>
                    <div class="group">
                        <span class="material-symbols-outlined text-terracotta-accent mb-4 block scale-125">hub</span>
                        <h4 class="font-display text-headline-sm text-ink-slate dark:text-inverse-on-surface mb-3 group-hover:text-terracotta-accent transition-colors">Align Teams for Flow</h4>
                        <p class="text-body-md text-on-surface-variant dark:text-outline-variant leading-relaxed">I use Team Topologies and Domain-Driven Design to align teams and technology, reducing handoffs, optimizing cognitive load, and improving performance.</p>
                    </div>
                </div>
            </section>

            <!-- Delivery Highlights -->
            <section class="mb-section-gap" id="highlights">
                <div class="bg-paper-white dark:bg-ink-slate p-8 md:p-12 border border-border-muted dark:border-outline-variant">
                    <div class="border-b border-border-muted dark:border-outline-variant pb-4 mb-8">
                        <h2 class="text-label-caps uppercase tracking-widest text-on-surface-variant dark:text-outline-variant">Delivery Highlights</h2>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-y-12 gap-x-8">
                        <div class="flex gap-4">
                            <span class="material-symbols-outlined text-ink-slate dark:text-inverse-on-surface shrink-0">account_balance</span>
                            <div>
                                <h5 class="font-bold mb-2 text-ink-slate dark:text-inverse-on-surface">Core Banking &amp; Payments</h5>
                                <p class="text-body-md text-on-surface-variant dark:text-outline-variant">Supported delivery of Scotiabank's U.S. Cash Management platform, Cross-Border Payments Transformation, and Scotia TranXact Payments APIs ($16M+).</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <span class="material-symbols-outlined text-ink-slate dark:text-inverse-on-surface shrink-0">database</span>
                            <div>
                                <h5 class="font-bold mb-2 text-ink-slate dark:text-inverse-on-surface">Data &amp; Compliance</h5>
                                <p class="text-body-md text-on-surface-variant dark:text-outline-variant">Guided teams in building Wealth Management Data Lake, supporting AML, KYC, and Fraud stakeholders.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <span class="material-symbols-outlined text-ink-slate dark:text-inverse-on-surface shrink-0">api</span>
                            <div>
                                <h5 class="font-bold mb-2 text-ink-slate dark:text-inverse-on-surface">Open Banking</h5>
                                <p class="text-body-md text-on-surface-variant dark:text-outline-variant">Facilitated the discovery and development of Open Banking APIs for Account Validation and real-time transaction monitoring.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <span class="material-symbols-outlined text-ink-slate dark:text-inverse-on-surface shrink-0">devices</span>
                            <div>
                                <h5 class="font-bold mb-2 text-ink-slate dark:text-inverse-on-surface">Digital Experience</h5>
                                <p class="text-body-md text-on-surface-variant dark:text-outline-variant">Agile Coach for ScotiaOnline and a $10M Salesforce implementation, leading discovery and delivery across five teams.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <span class="material-symbols-outlined text-ink-slate dark:text-inverse-on-surface shrink-0">medical_services</span>
                            <div>
                                <h5 class="font-bold mb-2 text-ink-slate dark:text-inverse-on-surface">HealthTech</h5>
                                <p class="text-body-md text-on-surface-variant dark:text-outline-variant">Supported delivery of a new Pharmacy Management System for Shopper's Drugmart in Quebec.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <span class="material-symbols-outlined text-ink-slate dark:text-inverse-on-surface shrink-0">payments</span>
                            <div>
                                <h5 class="font-bold mb-2 text-ink-slate dark:text-inverse-on-surface">FinTech</h5>
                                <p class="text-body-md text-on-surface-variant dark:text-outline-variant">Supported integrations with financial data aggregators, accounting software, and Earned Wage Access (EWA) providers.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Experience -->
            <section class="mb-section-gap" id="experience">
                <div class="border-t border-border-muted dark:border-outline-variant pt-4 mb-12">
                    <h2 class="text-label-caps uppercase tracking-widest text-on-surface-variant dark:text-outline-variant">Experience</h2>
                </div>
                <div class="w-full mx-auto">
                    <div class="mb-20">
                        <div class="flex justify-between items-baseline mb-4 border-b border-border-muted dark:border-outline-variant pb-2">
                            <h3 class="font-display text-3xl text-ink-slate dark:text-inverse-on-surface">Senior Agile Coach</h3>
                            <span class="text-mono-sm text-on-surface-variant dark:text-outline-variant">2019 — PRESENT</span>
                        </div>
                        <p class="font-bold text-terracotta-accent mb-6">Agile by Design</p>
                        <p class="text-body-lg text-on-surface-variant dark:text-outline-variant italic mb-10">Senior Agile SME and Transformation Coach with a focus on Wealth, Payments, and Healthcare. Expert in sociotechnical design, organizational flow, and high-performing teams.</p>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10">
                            <div>
                                <h5 class="flex items-center gap-2 font-bold mb-4 uppercase tracking-tighter text-xs text-ink-slate dark:text-inverse-on-surface">
                                    <span class="material-symbols-outlined text-terracotta-accent">workspace_premium</span>
                                    Program Delivery
                                </h5>
                                <ul class="space-y-3 text-body-md text-on-surface-variant dark:text-outline-variant">
                                    <li class="flex gap-2"><span>•</span> Led the delivery of complex systems across financial services and healthcare</li>
                                    <li class="flex gap-2"><span>•</span> Served as lead coach for large-scale initiatives, coordinating cross-functional teams</li>
                                    <li class="flex gap-2"><span>•</span> Facilitated collaborative modeling workshops to align stakeholders</li>
                                </ul>
                            </div>
                            <div>
                                <h5 class="flex items-center gap-2 font-bold mb-4 uppercase tracking-tighter text-xs text-ink-slate dark:text-inverse-on-surface">
                                    <span class="material-symbols-outlined text-terracotta-accent">account_tree</span>
                                    Socio-Technical Design
                                </h5>
                                <ul class="space-y-3 text-body-md text-on-surface-variant dark:text-outline-variant">
                                    <li class="flex gap-2"><span>•</span> Designed operating models using modern organizational patterns</li>
                                    <li class="flex gap-2"><span>•</span> Optimized value streams to significantly reduce lead times</li>
                                    <li class="flex gap-2"><span>•</span> Applied Team Topologies to reduce cognitive load</li>
                                </ul>
                            </div>
                            <div>
                                <h5 class="flex items-center gap-2 font-bold mb-4 uppercase tracking-tighter text-xs text-ink-slate dark:text-inverse-on-surface">
                                    <span class="material-symbols-outlined text-terracotta-accent">query_stats</span>
                                    Flow Engineering
                                </h5>
                                <ul class="space-y-3 text-body-md text-on-surface-variant dark:text-outline-variant">
                                    <li class="flex gap-2"><span>•</span> Replaced gut-feel deadlines with Monte Carlo simulations</li>
                                    <li class="flex gap-2"><span>•</span> Introduced Cost of Delay to enable data-informed decisions</li>
                                    <li class="flex gap-2"><span>•</span> Implemented percentile-driven lead time reporting</li>
                                </ul>
                            </div>
                            <div>
                                <h5 class="flex items-center gap-2 font-bold mb-4 uppercase tracking-tighter text-xs text-ink-slate dark:text-inverse-on-surface">
                                    <span class="material-symbols-outlined text-terracotta-accent">groups</span>
                                    Coaching Leadership
                                </h5>
                                <ul class="space-y-3 text-body-md text-on-surface-variant dark:text-outline-variant">
                                    <li class="flex gap-2"><span>•</span> Fostered high-autonomy and psychological safety through coaching</li>
                                    <li class="flex gap-2"><span>•</span> Designed training workshops on agile practices and flow</li>
                                    <li class="flex gap-2"><span>•</span> Introduced experimentation frameworks to accelerate learning</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="mb-20">
                        <div class="flex justify-between items-baseline mb-4 border-b border-border-muted dark:border-outline-variant pb-2">
                            <h3 class="font-display text-3xl text-ink-slate dark:text-inverse-on-surface">Agile Coach</h3>
                            <span class="text-mono-sm text-on-surface-variant dark:text-outline-variant">2017 — 2019</span>
                        </div>
                        <p class="font-bold text-terracotta-accent mb-4">Agile by Design</p>
                        <p class="text-body-md text-on-surface-variant dark:text-outline-variant leading-relaxed">Led the restructuring of a 400-person Wealth Management line of business, transitioning from siloed support to an integrated Build-and-Run model. Leveraged relative estimation and Monte Carlo simulations for data-driven planning.</p>
                    </div>

                    <div class="mb-10">
                        <div class="flex justify-between items-baseline mb-4 border-b border-border-muted dark:border-outline-variant pb-2">
                            <h3 class="font-display text-3xl text-ink-slate dark:text-inverse-on-surface">Data Analyst</h3>
                            <span class="text-mono-sm text-on-surface-variant dark:text-outline-variant">2013 — 2017</span>
                        </div>
                        <p class="font-bold text-terracotta-accent mb-4">Rubicon Project</p>
                        <p class="text-body-md text-on-surface-variant dark:text-outline-variant leading-relaxed">Leveraged data analytics and quantitative methods to support campaign optimization within the digital advertising ecosystem.</p>
                    </div>
                </div>
            </section>

            <!-- Published Tools -->
            <section class="mb-section-gap" id="tools">
                <div class="border-t border-border-muted dark:border-outline-variant pt-4 mb-12">
                    <h2 class="text-label-caps uppercase tracking-widest text-on-surface-variant dark:text-outline-variant">Published Tools</h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    <div class="bg-paper-white dark:bg-ink-slate p-5 border border-border-muted dark:border-outline-variant hover:border-terracotta-accent transition-all duration-300">
                        <span class="material-symbols-outlined text-ink-slate dark:text-inverse-on-surface mb-3 block">analytics</span>
                        <h4 class="font-display text-[18px] text-ink-slate dark:text-inverse-on-surface mb-1.5">Flow &amp; Analytics Platforms</h4>
                        <p class="text-body-md text-on-surface-variant dark:text-outline-variant">Built SquadView, Team Flow Mapping, and the DelayCost Visualizer to improve planning and work sequencing.</p>
                    </div>
                    <div class="bg-paper-white dark:bg-ink-slate p-5 border border-border-muted dark:border-outline-variant hover:border-terracotta-accent transition-all duration-300">
                        <span class="material-symbols-outlined text-ink-slate dark:text-inverse-on-surface mb-3 block">map</span>
                        <h4 class="font-display text-[18px] text-ink-slate dark:text-inverse-on-surface mb-1.5">Strategic Mapping</h4>
                        <p class="text-body-md text-on-surface-variant dark:text-outline-variant">Created the Wardley Doctrine &amp; AI Impact Explorer to develop services focused on user needs.</p>
                    </div>
                    <div class="bg-paper-white dark:bg-ink-slate p-5 border border-border-muted dark:border-outline-variant hover:border-terracotta-accent transition-all duration-300">
