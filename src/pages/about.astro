                        </a>
                        <a href="https://www.instagram.com/malcolmbastien/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-on-surface-variant dark:text-outline-variant hover:text-terracotta-accent transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.9 3.9 0 0 0-1.417.923A3.9 3.9 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.7.01 5.555 0 5.827 0 8.001c0 2.172.01 2.444.048 3.297.04.852.174 1.433.372 1.942.205.526.478.972.923 1.417.444.445.89.719 1.416.923.51.198 1.09.333 1.942.372C5.555 15.99 5.827 16 8 16s2.444-.01 3.298-.048c.851-.04 1.434-.174 1.943-.372a3.9 3.9 0 0 0 1.416-.923c.445-.445.718-.891.923-1.417.197-.509.332-1.09.372-1.942C15.99 10.445 16 10.173 16 8s-.01-2.445-.048-3.299c-.04-.851-.175-1.433-.372-1.941a3.9 3.9 0 0 0-.923-1.417A3.9 3.9 0 0 0 13.24.42c-.51-.198-1.092-.333-1.943-.372C10.443.01 10.172 0 7.998 0zm-.717 1.442h.718c2.136 0 2.389.007 3.232.046.78.035 1.204.166 1.486.275.373.145.64.319.92.599s.453.546.598.92c.11.281.24.705.275 1.485.039.843.047 1.096.047 3.231s-.008 2.389-.047 3.232c-.035.78-.166 1.203-.275 1.485a2.5 2.5 0 0 1-.599.919c-.28.28-.546.453-.92.598-.28.11-.704.24-1.485.276-.843.038-1.096.047-3.232.047s-2.39-.009-3.233-.047c-.78-.036-1.203-.166-1.485-.276a2.5 2.5 0 0 1-.92-.598 2.5 2.5 0 0 1-.6-.92c-.109-.281-.24-.705-.275-1.485-.038-.843-.046-1.096-.046-3.233s.008-2.388.046-3.231c.036-.78.166-1.204.276-1.486.145-.373.319-.64.599-.92s.546-.453.92-.598c.282-.11.705-.24 1.485-.276.738-.034 1.024-.044 2.515-.045zm4.988 1.328a.96.96 0 1 0 0 1.92.96.96 0 0 0 0-1.92m-4.27 1.122a4.109 4.109 0 1 0 0 8.217 4.109 4.109 0 0 0 0-8.217m0 1.441a2.667 2.667 0 1 1 0 5.334 2.667 2.667 0 0 1 0-5.334"/>
                            </svg>
                        </a>
                        <a href="https://www.threads.com/@malcolmbastien" target="_blank" rel="noopener noreferrer" aria-label="Threads" class="text-on-surface-variant dark:text-outline-variant hover:text-terracotta-accent transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M6.321 6.016c-.27-.18-1.166-.802-1.166-.802.756-1.081 1.753-1.502 3.132-1.502.975 0 1.803.327 2.394.948s.928 1.509 1.005 2.644q.492.207.905.484c1.109.745 1.719 1.86 1.719 3.137 0 2.716-2.226 5.075-6.256 5.075C4.594 16 1 13.987 1 7.994 1 2.034 4.482 0 8.044 0 9.69 0 13.55.243 15 5.036l-1.36.353C12.516 1.974 10.163 1.43 8.006 1.43c-3.565 0-5.582 2.171-5.582 6.79 0 4.143 2.254 6.343 5.63 6.343 2.777 0 4.847-1.443 4.847-3.556 0-1.438-1.208-2.127-1.27-2.127-.236 1.234-.868 3.31-3.644 3.31-1.618 0-3.013-1.118-3.013-2.582 0-2.09 1.984-2.847 3.55-2.847.586 0 1.294.04 1.663.114 0-.637-.54-1.728-1.9-1.728-1.25 0-1.566.405-1.967.868ZM8.716 8.19c-2.04 0-2.304.87-2.304 1.416 0 .878 1.043 1.168 1.6 1.168 1.02 0 2.067-.282 2.232-2.423a6.2 6.2 0 0 0-1.528-.161"/>
                            </svg>
                        </a>
                    </div>
                </div>
            </section>

            <!-- What I Do -->
            <section class="mb-section-gap" id="what-i-do">
                <div class="border-t border-border-muted dark:border-outline-variant pt-4 mb-12">
                    <h2 class="text-label-caps uppercase tracking-widest text-on-surface-variant dark:text-outline-variant">What I Do</h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                    <div class="group">
                        <span class="material-symbols-outlined text-terracotta-accent mb-4 block scale-125">trending_up</span>
                        <h4 class="font-display text-headline-sm text-ink-slate dark:text-inverse-on-surface mb-3 group-hover:text-terracotta-accent transition-colors">Promote Predictable Delivery</h4>
                        <p class="text-body-md text-on-surface-variant dark:text-outline-variant leading-relaxed">I help teams deliver better outcomes, faster, and more predictably by helping teams adopt agile-enabling practices and fostering a culture of rigorous continuous improvement.</p>
                    </div>
                    <div class="group">
                        <span class="material-symbols-outlined text-terracotta-accent mb-4 block scale-125">rocket_launch</span>
                        <h4 class="font-display text-headline-sm text-ink-slate dark:text-inverse-on-surface mb-3 group-hover:text-terracotta-accent transition-colors">Launch Complex Programs</h4>
                        <p class="text-body-md text-on-surface-variant dark:text-outline-variant leading-relaxed">I help organizations plan, organize, and run successful, high-stakes programs by breaking down ambiguous large-scale initiatives, aligning cross-functional stakeholders, and creating enabling team structures.</p>
                    </div>
                    <div class="group">
                        <span class="material-symbols-outlined text-terracotta-accent mb-4 block scale-125">groups</span>
                        <h4 class="font-display text-headline-sm text-ink-slate dark:text-inverse-on-surface mb-3 group-hover:text-terracotta-accent transition-colors">Empower Teams</h4>
                        <p class="text-body-md text-on-surface-variant dark:text-outline-variant leading-relaxed">I focus on building trust-based, high-performance environments where decision-making is moved to the team level, empowering them to solve their own challenges.</p>
                    </div>
                    <div class="group">
                        <span class="material-symbols-outlined text-terracotta-accent mb-4 block scale-125">hub</span>
                        <h4 class="font-display text-headline-sm text-ink-slate dark:text-inverse-on-surface mb-3 group-hover:text-terracotta-accent transition-colors">Align Teams for Flow</h4>
                        <p class="text-body-md text-on-surface-variant dark:text-outline-variant leading-relaxed">I use Team Topologies and Domain-Driven Design to align teams and technology, reducing handoffs, optimizing cognitive load, and improving performance.</p>
                    </div>
                </div>
            </section>

            <!-- Delivery Highlights -->
            <section class="mb-section-gap" id="highlights">
                <div class="bg-paper-white dark:bg-ink-slate p-8 md:p-12 border border-border-muted dark:border-outline-variant">
                    <div class="border-b border-border-muted dark:border-outline-variant pb-4 mb-8">
                        <h2 class="text-label-caps uppercase tracking-widest text-on-surface-variant dark:text-outline-variant">Delivery Highlights</h2>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-y-12 gap-x-8">
                        <div class="flex gap-4">
                            <span class="material-symbols-outlined text-ink-slate dark:text-inverse-on-surface shrink-0">account_balance</span>
                            <div>
                                <h5 class="font-bold mb-2 text-ink-slate dark:text-inverse-on-surface">Core Banking &amp; Payments</h5>
                                <p class="text-body-md text-on-surface-variant dark:text-outline-variant">Supported delivery of a major Canadian bank's U.S. Cash Management platform, Cross-Border Payments Transformation, and corporate payments APIs.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <span class="material-symbols-outlined text-ink-slate dark:text-inverse-on-surface shrink-0">database</span>
                            <div>
                                <h5 class="font-bold mb-2 text-ink-slate dark:text-inverse-on-surface">Data &amp; Compliance</h5>
                                <p class="text-body-md text-on-surface-variant dark:text-outline-variant">Guided teams in building Wealth Management Data Lake, supporting AML, KYC, and Fraud stakeholders.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <span class="material-symbols-outlined text-ink-slate dark:text-inverse-on-surface shrink-0">api</span>
                            <div>
                                <h5 class="font-bold mb-2 text-ink-slate dark:text-inverse-on-surface">Open Banking</h5>
                                <p class="text-body-md text-on-surface-variant dark:text-outline-variant">Facilitated the discovery and development of Open Banking APIs for Account Validation and real-time transaction monitoring.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <span class="material-symbols-outlined text-ink-slate dark:text-inverse-on-surface shrink-0">devices</span>
                            <div>
                                <h5 class="font-bold mb-2 text-ink-slate dark:text-inverse-on-surface">Digital Experience</h5>
                                <p class="text-body-md text-on-surface-variant dark:text-outline-variant">Agile Coach for a digital banking platform and a major CRM implementation, leading discovery and delivery across five teams.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <span class="material-symbols-outlined text-ink-slate dark:text-inverse-on-surface shrink-0">medical_services</span>
                            <div>
                                <h5 class="font-bold mb-2 text-ink-slate dark:text-inverse-on-surface">HealthTech</h5>
                                <p class="text-body-md text-on-surface-variant dark:text-outline-variant">Supported delivery of a new Pharmacy Management System for a national pharmacy chain in Quebec.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <span class="material-symbols-outlined text-ink-slate dark:text-inverse-on-surface shrink-0">payments</span>
                            <div>
                                <h5 class="font-bold mb-2 text-ink-slate dark:text-inverse-on-surface">Fintech</h5>
                                <p class="text-body-md text-on-surface-variant dark:text-outline-variant">Supported integrations with financial data aggregators, accounting software, and Earned Wage Access (EWA) providers.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <span class="material-symbols-outlined text-ink-slate dark:text-inverse-on-surface shrink-0">cloud</span>
                            <div>
                                <h5 class="font-bold mb-2 text-ink-slate dark:text-inverse-on-surface">Cloud &amp; Managed Services</h5>
                                <p class="text-body-md text-on-surface-variant dark:text-outline-variant">Designed and implemented a strategy operations portfolio Kanban board for a cloud services provider, based on the Flight Levels Model.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Experience -->
            <section class="mb-section-gap" id="experience">
                <div class="border-t border-border-muted dark:border-outline-variant pt-4 mb-12">
                    <h2 class="text-label-caps uppercase tracking-widest text-on-surface-variant dark:text-outline-variant">Experience</h2>
                </div>
                <div class="w-full mx-auto">
                    <div class="mb-20">
                        <div class="flex justify-between items-baseline mb-4 border-b border-border-muted dark:border-outline-variant pb-2">
                            <h3 class="font-display text-3xl text-ink-slate dark:text-inverse-on-surface">Agile Coach</h3>
                            <span class="text-mono-sm text-on-surface-variant dark:text-outline-variant">2026 — Present</span>
                        </div>
                        <p class="font-bold text-terracotta-accent mb-6">CIBC</p>
                    </div>

                    <div class="mb-20">
                        <div class="flex justify-between items-baseline mb-4 border-b border-border-muted dark:border-outline-variant pb-2">
                            <h3 class="font-display text-3xl text-ink-slate dark:text-inverse-on-surface">Senior Agile Coach</h3>
                            <span class="text-mono-sm text-on-surface-variant dark:text-outline-variant">2019 — 2026</span>
                        </div>
                        <p class="font-bold text-terracotta-accent mb-3">Agile by Design</p>
                        <div class="bg-paper-white dark:bg-ink-slate border border-border-muted dark:border-outline-variant p-6 mb-6">
                            <p class="text-label-caps uppercase tracking-widest text-on-surface-variant dark:text-outline-variant mb-3">About the company</p>
                            <p class="text-body-md text-on-surface-variant dark:text-outline-variant leading-relaxed">Toronto-based agile consultancy (founded 2015) that embeds delivery leaders inside client teams to improve flow, delivery performance, and operating model outcomes. Engagements include turning around $100M programs and driving 10× delivery-frequency gains. Led by Jeff Anderson, a published author and frequent speaker on modern agile practice.</p>
                        </div>
                        <p class="text-body-lg text-on-surface-variant dark:text-outline-variant italic mb-10">Senior Agile SME and Transformation Coach with a focus on Wealth, Payments, and Healthcare. Expert in sociotechnical design, organizational flow, and high-performing teams.</p>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10">
                            <div>
                                <h5 class="flex items-center gap-2 font-bold mb-4 uppercase tracking-tighter text-xs text-ink-slate dark:text-inverse-on-surface">
                                    <span class="material-symbols-outlined text-terracotta-accent">workspace_premium</span>
                                    Delivery &amp; Coaching
                                </h5>
                                <ul class="space-y-3 text-body-md text-on-surface-variant dark:text-outline-variant">
                                    <li class="flex gap-2"><span>•</span> Led the delivery of complex systems across financial services and healthcare</li>
                                    <li class="flex gap-2"><span>•</span> Served as lead coach for large-scale initiatives, coordinating cross-functional teams</li>
                                    <li class="flex gap-2"><span>•</span> Led collaborative modelling sessions using EventStorming and Domain Storytelling to bridge business logic and software architecture</li>
                                    <li class="flex gap-2"><span>•</span> Fostered high-autonomy and psychological safety through coaching</li>
                                    <li class="flex gap-2"><span>•</span> Designed training workshops on agile practices and flow</li>
                                    <li class="flex gap-2"><span>•</span> Introduced experimentation frameworks to accelerate learning</li>
                                </ul>
                            </div>
                            <div>
                                <h5 class="flex items-center gap-2 font-bold mb-4 uppercase tracking-tighter text-xs text-ink-slate dark:text-inverse-on-surface">
                                    <span class="material-symbols-outlined text-terracotta-accent">account_tree</span>
                                    Socio-Technical Design
                                </h5>
                                <ul class="space-y-3 text-body-md text-on-surface-variant dark:text-outline-variant">
                                    <li class="flex gap-2"><span>•</span> Designed operating models using modern organizational patterns</li>
                                    <li class="flex gap-2"><span>•</span> Optimized value streams for fraud screening and client onboarding, reducing lead times and time-to-value</li>
                                    <li class="flex gap-2"><span>•</span> Applied Team Topologies and DDD to restructure team boundaries, reducing cognitive load and cross-team dependencies</li>
                                    <li class="flex gap-2"><span>•</span> Implemented Flight Levels system to visualize and manage portfolio operations and team-level delivery</li>
                                </ul>
                            </div>
                            <div>
                                <h5 class="flex items-center gap-2 font-bold mb-4 uppercase tracking-tighter text-xs text-ink-slate dark:text-inverse-on-surface">
                                    <span class="material-symbols-outlined text-terracotta-accent">query_stats</span>
                                    Flow Engineering
                                </h5>
                                <ul class="space-y-3 text-body-md text-on-surface-variant dark:text-outline-variant">
                                    <li class="flex gap-2"><span>•</span> Replaced gut-feel deadlines with Monte Carlo simulations for range-based commitments</li>
                                    <li class="flex gap-2"><span>•</span> Introduced Cost of Delay and custom prioritization frameworks for objective backlog sequencing</li>
                                    <li class="flex gap-2"><span>•</span> Implemented percentile-driven lead time and age of WIP reporting to improve predictability</li>
                                </ul>
                            </div>
                            <div>
                                <h5 class="flex items-center gap-2 font-bold mb-4 uppercase tracking-tighter text-xs text-ink-slate dark:text-inverse-on-surface">
                                    <span class="material-symbols-outlined text-terracotta-accent">psychology</span>
