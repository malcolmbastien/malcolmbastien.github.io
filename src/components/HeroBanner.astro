---
import { Picture } from "astro:assets";
import malcolmHeadshot from "/src/assets/malcolm_headshot.png";
---

<header class="pt-28 pb-16 border-b border-slate-200/50 dark:border-slate-800/50 bg-white dark:bg-slate-950">
    <div class="max-w-7xl mx-auto px-6">
        <div class="flex flex-col md:flex-row items-start gap-12">
            <div class="w-32 h-32 md:w-48 md:h-48 shrink-0">
                <Picture
                    src={malcolmHeadshot}
                    alt="Malcolm Bastien"
                    class="w-full h-full object-cover"
                />
            </div>
            <div class="max-w-4xl">
                <h1 class="text-5xl md:text-6xl font-extrabold tracking-tighter leading-[1.1] text-slate-900 dark:text-white mb-8">
                    Designing for Business Agility & <span class="text-blue-600">Organizational Flow.</span>
                </h1>
                <p class="text-xl leading-relaxed text-slate-600 dark:text-slate-400 max-w-3xl font-medium">
                    I am Malcolm Bastien, an expert in Agile Delivery and Organizational Change. I help organizations remove friction and improve flow to enable high-performance delivery at scale.
                </p>
            </div>
        </div>
    </div>
</header>
