---
const currentYear = new Date().getFullYear();
---

<footer class="w-full py-12 border-t border-slate-200/50 dark:border-slate-800/50 bg-white dark:bg-slate-950">
    <div class="flex flex-col md:flex-row justify-between items-center px-6 max-w-7xl mx-auto gap-8">
        <div class="text-slate-900 dark:text-white font-extrabold text-[0.7rem] uppercase tracking-[0.2em]">
            Flow Focused
        </div>
        <div class="flex gap-10">
            <a class="text-slate-500 dark:text-slate-400 text-[0.7rem] uppercase tracking-widest font-bold hover:text-slate-900 dark:hover:text-white transition-colors" href="/">Garden</a>
            <a class="text-slate-500 dark:text-slate-400 text-[0.7rem] uppercase tracking-widest font-bold hover:text-slate-900 dark:hover:text-white transition-colors" href="/topics">Topics</a>
            <a class="text-slate-500 dark:text-slate-400 text-[0.7rem] uppercase tracking-widest font-bold hover:text-slate-900 dark:hover:text-white transition-colors" href="/about">About</a>
        </div>
        <div class="text-slate-500 dark:text-slate-400 font-bold text-[0.6rem] uppercase tracking-widest">
            © {currentYear} Flow Focused. The Blueprint for Systems.
        </div>
    </div>
</footer>
