---
import { getStageData } from "../lib/theme";

interface Props {
    backlinkedNotes: any[];
}

const { backlinkedNotes: rawBacklinkedNotes } = Astro.props;

const backlinkedNotes = rawBacklinkedNotes
    .map((note) => {
        const displayDate = note.data.publishedDate || new Date();
        return { ...note, displayDate };
    })
    .sort((a, b) => b.displayDate.getTime() - a.displayDate.getTime());

const getStageBadgeClass = (stage: string) => {
    switch (stage) {
        case 'seed':
            return 'bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400';
        case 'sprout':
            return 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400';
        case 'evergreen':
            return 'bg-emerald-600 text-white';
        default:
            return 'bg-slate-100 text-slate-700';
    }
};
---

{
    backlinkedNotes.length > 0 && (
        <section>
            <div class="flex items-center gap-3 mb-8">
                <h3 class="small-caps text-xs font-bold tracking-[0.2em] text-slate-500 dark:text-slate-400">Connected Notes</h3>
                <div class="h-px bg-slate-100 dark:bg-slate-800 grow"></div>
                <span class="text-[10px] font-medium text-slate-400 dark:text-slate-500">{backlinkedNotes.length} links</span>
            </div>

            <div>
                {backlinkedNotes.map((note) => (
                    <a href={`/notes/${note.id.replace('.md', '')}`} class="group block cursor-pointer">
                        <div class="flex-1">
                            <time class="text-[0.7rem] uppercase tracking-[0.2em] font-bold text-slate-500 dark:text-slate-400 mb-2 block leading-none">
                                {note.displayDate.toLocaleDateString("en-US", {
                                    month: 'short',
                                    day: 'numeric',
                                    year: 'numeric',
                                    timeZone: 'UTC'
                                })}
                            </time>
                            <h4 class="text-3xl font-extrabold tracking-tight text-slate-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors leading-tight -mt-1">
                                {note.data.title}
                            </h4>
                            {note.data.summary && (
                                <p class="text-slate-600 dark:text-slate-400 text-base leading-relaxed max-w-xl">
                                    {note.data.summary}
                                </p>
                            )}
                        </div>
                    </a>
                ))}
            </div>
        </section>
    )
}
