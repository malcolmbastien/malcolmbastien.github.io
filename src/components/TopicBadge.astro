---
interface Props {
    topic: string;
    count?: number;
    size?: 'sm' | 'md';
}

const { topic, count, size = 'md' } = Astro.props;

const sizeClasses = size === 'sm' 
    ? 'text-xs px-3 py-2' 
    : 'text-sm px-4 py-2';
---

<a
    href={`/topics/${topic.replace(/\s+/g, '-')}`}
    class={`inline-flex items-center gap-1.5 ${sizeClasses} bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-full font-medium text-slate-600 dark:text-slate-300 hover:border-primary hover:bg-primary hover:text-white dark:hover:bg-primary dark:hover:text-white transition-all duration-300`}
>
    <span class="text-slate-400">#</span>{topic}
    {count !== undefined && (
        <span class="text-xs text-slate-400">{count}</span>
    )}
</a>
