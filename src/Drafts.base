views:
  - type: table
    name: Table
    filters:
      and:
        - file.inFolder("content/notes")
        - draft == true
    order:
      - file.name
      - title
      - file.mtime
    sort:
      - property: file.name
        direction: ASC
      - property: file.mtime
        direction: ASC
    columnSize:
      file.name: 499
